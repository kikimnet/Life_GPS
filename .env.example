# LifeGPS Environment Variables
# Copy this file to .env.local and fill in your values

# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE

# Stripe Price IDs (create in Stripe Dashboard → Products)
VITE_STRIPE_PRO_PRICE_ID=price_YOUR_PRO_PRICE_ID
VITE_STRIPE_PREMIUM_PRICE_ID=price_YOUR_PREMIUM_PRICE_ID

# Stripe Webhook Secret (for Edge Functions)
# STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# ─── PostHog Analytics ───────────────────────────────────────────────────────
# Get from: https://app.posthog.com → Settings
VITE_POSTHOG_KEY=phc_YOUR_KEY_HERE
VITE_POSTHOG_HOST=https://app.posthog.com
